REPOOPS_ENV=local
REPOOPS_MODEL_PROVIDER=none
REPOOPS_MODEL_NAME=gpt-5.4-mini
REPOOPS_OPENAI_API_KEY=
REPOOPS_GITHUB_TOKEN=
REPOOPS_ENABLE_LLM_SYNTHESIS=false
REPOOPS_INDEX_ROOT=data/indexes
REPOOPS_MAX_TOOL_ROUNDS=2
REPOOPS_MAX_TOOL_CALLS_PER_ROUND=3
REPOOPS_MAX_EVIDENCE_ITEMS=8
REPOOPS_MAX_INVESTIGATION_ROUNDS=2
REPOOPS_MAX_INVESTIGATION_QUERIES_PER_ROUND=3
REPOOPS_GITHUB_SEARCH_CACHE=true
